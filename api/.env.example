# Secret pour l'access_token (durée courte, ex: 15m)
JWT_SECRET=Secret_JWT_confidentiel

# Secret pour le refresh_token (durée longue, ex: 7d)
JWT_REFRESH_SECRET=Secret_JWT_refresh_confidentiel

# DATABASE_NAME=database.sqlite

DB_HOST=localhost
DB_PORT=5433
DB_USER=jobview-user
DB_PASSWORD=jobview-password
DB_NAME=jobview-database
# DB_SYNCHRONIZE=true

PORT=3001

# Ollama LLM — defaults assume a locally installed Ollama when running the API outside docker.
# In docker-compose, these are overridden to http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b